#: ../../source/pytest.rst:192
msgid "Markers"
msgstr "Маркеры"

#: ../../source/pytest.rst:194
msgid "``@pytest.mark.catch_loop_exceptions``"
msgstr "``@pytest.mark.catch_loop_exceptions``"

#: ../../source/pytest.rst:195
msgid "Uncaught event loop exceptions will fail the test."
msgstr "Необработанные исключения цикла событий приведут к провалу теста."

#: ../../source/pytest.rst:197
msgid ""
"import asyncio\n"
"import pytest\n"
"\n"
"\n"
"@pytest.mark.catch_loop_exceptions\n"
"async def test_with_errors(event_loop):\n"
"    async def fail():\n"
"        await asyncio.sleep(0)\n"
"        raise Exception()\n"
"\n"
"    event_loop.create_task(fail())\n"
"    await asyncio.sleep(0.1)"
msgstr ""

#: ../../source/pytest.rst:212
msgid "``@pytest.mark.forbid_get_event_loop``"
msgstr "``@pytest.mark.forbid_get_event_loop``"

#: ../../source/pytest.rst:213
msgid "Forbids calling ``asyncio.get_event_loop()`` during the test."
msgstr "Запрещает вызов ``asyncio.get_event_loop()`` во время теста."

#: ../../source/pytest.rst:215
msgid ""
"import asyncio\n"
"import pytest\n"
"\n"
"\n"
"@pytest.mark.forbid_get_event_loop\n"
"async def test_no_get_loop():\n"
"    def bad():\n"
"        asyncio.get_event_loop()\n"
"\n"
"    with pytest.raises(Exception):\n"
"        bad()"
msgstr ""

